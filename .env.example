# =====================================================================
# 1. Lovable-managed Supabase (existing) — powers the AI chat function
#    Public, bundled into the client.
# =====================================================================
VITE_SUPABASE_URL=https://your-lovable-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-lovable-anon-key
VITE_SUPABASE_PROJECT_ID=your-lovable-project-id

# =====================================================================
# 2. Publications-only Supabase (separate project)
#    Public, bundled into the client. Used by the "Жарияланымдар"
#    tab on each school profile.
# =====================================================================
VITE_PUBLICATIONS_SUPABASE_URL=https://your-publications-project.supabase.co
VITE_PUBLICATIONS_SUPABASE_ANON_KEY=sb_publishable_xxx_or_eyJ...

# =====================================================================
# 3. Server-only — sync script secrets.
#    Put these into .env.local (gitignored). NEVER bundle into the client.
#    Get from Supabase Studio → Project Settings → API → service_role.
# =====================================================================
# PUBLICATIONS_SUPABASE_URL=https://your-publications-project.supabase.co
# PUBLICATIONS_SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx_or_eyJ...
#
# Optional override for the publications root folder
# (default: ~/Desktop/Все школы)
# LOCAL_PUBLICATIONS_ROOT=/Users/you/Desktop/Все школы
